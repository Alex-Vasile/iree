index 000000000000..1de3fa924f98
--- /dev/null
+++ b/mlir/test/Integration/Dialect/Tensor/CPU/strided-insert-slice-num-threads.mlir
@@ -0,0 +1,57 @@
+// EXEC gate (Approach 1, Phase 0) — G4b (numThreads, real-IREE offset path):
+// does initial tiling of a real tensor.insert_slice via `num_threads` (the path
+// IREE dispatches on, NOT literal `tile_sizes`) lower end-to-end and write the
+// correct genuine-scatter cells? ceilDiv(4,2)=2 source rows per tile -> 2 tiles,
+// EACH a genuine within-tile scatter (size 2 on the strided dim, not vestigial).
+//
+// RED today only because mlir-runner is still building; GREEN after Stage 3's
+// impl. This is the load-bearing EXEC for the real-IREE offset path (the
+// `num_threads` branch computes per-tile offsets via *different code* than the
+// `tile_sizes` branch, so a G4a-only green would not cover it).
+//
+// Kernel: source<4x4> scattered into dest<8x4> with stride [2,1], num_threads [2,1]
+// -> source row j lands at dest row 0+j*2 = dest rows {0,2,4,6}. Over a
+// zero-initialized dest the result is rows {0,2,4,6}=1, odd rows 0.
+
+// RUN: mlir-opt %s -transform-interpreter -test-transform-dialect-erase-schedule \
+// RUN:   -one-shot-bufferize="bufferize-function-boundaries" -buffer-deallocation-pipeline \
+// RUN:   -cse -canonicalize --test-lower-to-llvm -o %t
+// RUN: mlir-runner %t -e main_caseB -entry-point-result=void \
+// RUN:   -shared-libs=%mlir_runner_utils,%mlir_c_runner_utils | FileCheck %s --check-prefix=G4B
+
+func.func @main_caseB() {
+  %c0 = arith.constant 0 : i32
+  %c1 = arith.constant 1 : i32
+  // Zero-initialized destination (8 rows).
+  %alloc = tensor.empty() : tensor<8x4xi32>
+  %dest = linalg.fill ins(%c0 : i32) outs(%alloc : tensor<8x4xi32>) -> tensor<8x4xi32>
+  // Source tile of ones (4 rows).
+  %init = tensor.empty() : tensor<4x4xi32>
+  %filled = linalg.fill ins(%c1 : i32) outs(%init : tensor<4x4xi32>) -> tensor<4x4xi32>
+  // The anchor: strided scatter, source row j -> dest row 0 + j*2.
+  %r = tensor.insert_slice %filled into %dest[0, 0] [4, 4] [2, 1]
+        : tensor<4x4xi32> into tensor<8x4xi32>
+  %xf = tensor.cast %r : tensor<8x4xi32> to tensor<*xi32>
+  // G4B:      data =
+// G4B-NEXT: {{\[1, +1, +1, +1\]}}
+// G4B-NEXT: {{\[0, +0, +0, +0\]}}
+// G4B-NEXT: {{\[1, +1, +1, +1\]}}
+// G4B-NEXT: {{\[0, +0, +0, +0\]}}
+// G4B-NEXT: {{\[1, +1, +1, +1\]}}
+// G4B-NEXT: {{\[0, +0, +0, +0\]}}
+// G4B-NEXT: {{\[1, +1, +1, +1\]}}
+// G4B-NEXT: {{\[0, +0, +0, +0\]}}
+  call @printMemrefI32(%xf) : (tensor<*xi32>) -> ()
+  return
+}
+
+func.func private @printMemrefI32(%ptr : tensor<*xi32>)
+
+module attributes {transform.with_named_sequence} {
+  transform.named_sequence @__transform_main(%arg1: !transform.any_op {transform.readonly}) {
+    %0 = transform.structured.match ops{["tensor.insert_slice"]} in %arg1 : (!transform.any_op) -> !transform.any_op
+    %tiled, %forall = transform.structured.tile_using_forall %0 num_threads [2, 1]
+      : (!transform.any_op) -> (!transform.any_op, !transform.any_op)
+    transform.yield
+  }
+}
