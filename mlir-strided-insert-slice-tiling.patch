     tensor::PadOp::attachInterface<PadOpTiling>(*ctx);
+    tensor::InsertSliceOp::attachInterface<InsertSliceOpTiling>(*ctx);
   });
 }
diff --git a/mlir/test/Dialect/Tensor/tiling-insert-slice-offset.mlir b/mlir/test/Dialect/Tensor/tiling-insert-slice-offset.mlir
new file mode 100644
index 000000000000..c862a9ef711c
--- /dev/null
+++ b/mlir/test/Dialect/Tensor/tiling-insert-slice-offset.mlir
@@ -0,0 +1,92 @@
+// RUN: mlir-opt --transform-interpreter --split-input-file -canonicalize %s | FileCheck %s
+
+// Granular OFFSET verification — complements tiling-insert-slice-strided.mlir
+// (which checks the raw emitted writeback's sizes+strides). This file runs
+// -canonicalize so the 1-tile cases fold to a plain `tensor.insert_slice` with
+// LITERAL offsets, letting each piece — offset, size, stride — be pinned
+// independently. A failure then localizes to the exact wrong piece:
+//   - wrong offset  -> the `[x, y]` literal mismatches
+//   - wrong size     -> the `[2, 4]` mismatches (the F1 `resultSizes=iterSizes`
+//                       convention; the discarded `*stride` span would print a
+//                       different size)
+//   - wrong stride   -> the trailing `[2, 1]` mismatches
+// The 2-tile case (off_caseB) does not fold; it pins that the writeback offset
+// is computed via `affine.apply` (the stride multiplier), distinct from the
+// extract's raw iteration variable — catching the "stride not multiplied into
+// the offset" bug that the constant-offset 1-tile cases cannot.
+
+// === off_caseA: base [0,0], full-source 1-tile (tile_sizes [2,4]) ===
+//   Folds to a literal insert_slice; offset = base + 0*stride = [0,0].
+module attributes {transform.with_named_sequence} {
+  transform.named_sequence @__transform_main(%arg1: !transform.any_op {transform.readonly}) {
+    %0 = transform.structured.match ops{["tensor.insert_slice"]} in %arg1 : (!transform.any_op) -> !transform.any_op
+    %tiled, %forall = transform.structured.tile_using_forall %0 tile_sizes [2, 4]
+      : (!transform.any_op) -> (!transform.any_op, !transform.any_op)
+    transform.yield
+  }
+}
+// CHECK-LABEL: func @off_caseA
+// CHECK: tensor.{{(parallel_)?}}insert_slice {{.*}}[0, 0] [2, 4] [2, 1]
+func.func @off_caseA(%dest: tensor<4x4xi32>) -> tensor<4x4xi32> {
+  %c1 = arith.constant 1 : i32
+  %init = tensor.empty() : tensor<2x4xi32>
+  %filled = linalg.fill ins(%c1 : i32) outs(%init : tensor<2x4xi32>) -> tensor<2x4xi32>
+  %r = tensor.insert_slice %filled into %dest[0, 0] [2, 4] [2, 1]
+        : tensor<2x4xi32> into tensor<4x4xi32>
+  return %r : tensor<4x4xi32>
+}
+
+// -----
+
+// === off_caseC: NON-ZERO base [2,0], full-source 1-tile (tile_sizes [2,4]) ===
+//   Folds to a literal insert_slice; offset = base + 0*stride = [2,0].
+//   This is the case that pins BASE addition: if the impl dropped the base,
+//   the offset would be [0,0] (off_caseA passes either way, since its base is 0).
+module attributes {transform.with_named_sequence} {
+  transform.named_sequence @__transform_main(%arg1: !transform.any_op {transform.readonly}) {
+    %0 = transform.structured.match ops{["tensor.insert_slice"]} in %arg1 : (!transform.any_op) -> !transform.any_op
+    %tiled, %forall = transform.structured.tile_using_forall %0 tile_sizes [2, 4]
+      : (!transform.any_op) -> (!transform.any_op, !transform.any_op)
+    transform.yield
+  }
+}
+// CHECK-LABEL: func @off_caseC
+// CHECK: tensor.{{(parallel_)?}}insert_slice {{.*}}[2, 0] [2, 4] [2, 1]
+func.func @off_caseC(%dest: tensor<6x4xi32>) -> tensor<6x4xi32> {
+  %c1 = arith.constant 1 : i32
+  %init = tensor.empty() : tensor<2x4xi32>
+  %filled = linalg.fill ins(%c1 : i32) outs(%init : tensor<2x4xi32>) -> tensor<2x4xi32>
+  %r = tensor.insert_slice %filled into %dest[2, 0] [2, 4] [2, 1]
+        : tensor<2x4xi32> into tensor<6x4xi32>
+  return %r : tensor<6x4xi32>
+}
+
+// -----
+
+// === off_caseB: base [0,0], 2-tile (tile_sizes [1,4]) — forall survives ===
+//   The extract's dim-0 offset is the raw IV (tilesize 1), but the writeback's
+//   dim-0 offset is an `affine.apply` of the stride(2) map on the IV. That
+//   contrast pins the stride multiplier in the offset: a bug that dropped the
+//   stride would make the writeback offset the raw IV (no affine.apply).
+module attributes {transform.with_named_sequence} {
+  transform.named_sequence @__transform_main(%arg1: !transform.any_op {transform.readonly}) {
+    %0 = transform.structured.match ops{["tensor.insert_slice"]} in %arg1 : (!transform.any_op) -> !transform.any_op
+    %tiled, %forall = transform.structured.tile_using_forall %0 tile_sizes [1, 4]
+      : (!transform.any_op) -> (!transform.any_op, !transform.any_op)
+    transform.yield
+  }
+}
+// CHECK-LABEL: func @off_caseB
+// extract dim-0 offset is the raw iteration variable (tile size 1):
+// CHECK: tensor.extract_slice {{.*}}[%{{[a-z0-9_]+}}, 0] [1, 4] [1, 1]
+// writeback dim-0 offset is COMPUTED via affine.apply (stride applied):
+// CHECK: %[[OFF:.*]] = affine.apply
+// CHECK: tensor.parallel_insert_slice {{.*}}[%[[OFF]], 0] [1, 4] [2, 1]
+func.func @off_caseB(%dest: tensor<4x4xi32>) -> tensor<4x4xi32> {
+  %c1 = arith.constant 1 : i32
+  %init = tensor.empty() : tensor<2x4xi32>
+  %filled = linalg.fill ins(%c1 : i32) outs(%init : tensor<2x4xi32>) -> tensor<2x4xi32>
+  %r = tensor.insert_slice %filled into %dest[0, 0] [2, 4] [2, 1]
+        : tensor<2x4xi32> into tensor<4x4xi32>
+  return %r : tensor<4x4xi32>
+}
diff --git a/mlir/test/Dialect/Tensor/tiling-insert-slice-strided.mlir b/mlir/test/Dialect/Tensor/tiling-insert-slice-strided.mlir
new file mode 100644
index 000000000000..db002b868a6b
--- /dev/null
+++ b/mlir/test/Dialect/Tensor/tiling-insert-slice-strided.mlir
@@ -0,0 +1,125 @@
+// RUN: mlir-opt --transform-interpreter --split-input-file %s | FileCheck %s
+
+// Capability probe (Approach 1, Phase 0): can initial tiling of a real
+// tensor.insert_slice emit a NON-UNIT-STRIDED writeback via the
+// getResultTilePosition contract?
+//
+// RED (today): every section FAILS at
+//   LinalgTransformOps.cpp:3899  auto tileableOp = dyn_cast<TilingInterface>(target);
+//   if (!tileableOp) -> "only TilingInterface ops are supported"
+// because tensor.insert_slice is NOT registered as TilingInterface
+// (TensorTilingInterfaceImpl.cpp:314 attaches only PadOpTiling to tensor.pad).
+// GREEN (Stage 3) emits the strided per-tile writeback asserted by the CHECKs.
+//
+// Sub-case A is the PRIMARY capability proof (genuine scatter: strided dim has
+// size >= 2, so the [2,1] stride is load-bearing — a hardcoded [1,1] writeback
+// would place tile row 1 at dest row 1, not row 2). Sub-case B (size-1 strided
+// dim) is a vestigial-stride false-green on its own; it only proves the strided
+// *offset* composition. R4 twins guard the unit-stride path against regression.
+
+// === sub-case A (PRIMARY, genuine scatter): tile_sizes [2,4] -> 1-tile,
+//     source row j -> dest row 0+j*2 = dest rows {0,2} ===
+module attributes {transform.with_named_sequence} {
+  transform.named_sequence @__transform_main(%arg1: !transform.any_op {transform.readonly}) {
+    %0 = transform.structured.match ops{["tensor.insert_slice"]} in %arg1 : (!transform.any_op) -> !transform.any_op
+    %tiled, %forall = transform.structured.tile_using_forall %0 tile_sizes [2, 4]
+      : (!transform.any_op) -> (!transform.any_op, !transform.any_op)
+    transform.yield
+  }
+}
+
+// CHECK-LABEL: func @strided_write_2x_caseA
+func.func @strided_write_2x_caseA(%dest: tensor<4x4xi32>) -> tensor<4x4xi32> {
+  %c1 = arith.constant 1 : i32
+  %init = tensor.empty() : tensor<2x4xi32>
+  %filled = linalg.fill ins(%c1 : i32) outs(%init : tensor<2x4xi32>) -> tensor<2x4xi32>
+  // source<2x4>; source row j -> dest row 0 + j*2 = dest rows {0,2}
+  %r = tensor.insert_slice %filled into %dest[0, 0] [2, 4] [2, 1]
+        : tensor<2x4xi32> into tensor<4x4xi32>
+  return %r : tensor<4x4xi32>
+}
+// G3 (PRIMARY): contiguous source extract + GENUINE-STRIDE writeback.
+//   The [2,4] sizes (== source) AND [2,1] strides together are load-bearing:
