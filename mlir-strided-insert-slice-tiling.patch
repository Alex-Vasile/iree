diff --git a/mlir/lib/Dialect/Tensor/IR/TensorTilingInterfaceImpl.cpp b/mlir/lib/Dialect/Tensor/IR/TensorTilingInterfaceImpl.cpp
index 124a63281a37..7c524e807ecf 100644
--- a/mlir/lib/Dialect/Tensor/IR/TensorTilingInterfaceImpl.cpp
+++ b/mlir/lib/Dialect/Tensor/IR/TensorTilingInterfaceImpl.cpp
@@ -83,6 +83,91 @@ struct PadOpTiling : public TilingInterface::ExternalModel<PadOpTiling, PadOp> {
   }
 };

+/// Tiling model for `tensor.insert_slice` that treats the op as a strided
+/// writeback: the iteration domain is the *source* tensor shape, the tiled
+/// implementation is a contiguous `tensor.extract_slice` of the source, and the
+/// result position/strides place the tile back into the destination with the
+/// insert_slice's own offsets/sizes/strides. The stride thus flows from the
+/// slice op's geometry into the surrounding loop's writeback (via
+/// `getResultTileStrides`), enabling non-unit-strided (dilated/scattered)
+/// per-tile writes. Rank-reduced insert_slice is not handled (iteration domain
+/// is the source rank; result position is the dest rank) and bails to avoid
+/// inconsistent IR.
+struct InsertSliceOpTiling
+    : public TilingInterface::ExternalModel<InsertSliceOpTiling, InsertSliceOp> {
+
+  SmallVector<utils::IteratorType> getLoopIteratorTypes(Operation *op) const {
+    auto insertOp = cast<InsertSliceOp>(op);
+    return SmallVector<utils::IteratorType>(insertOp.getSourceType().getRank(),
+                                            utils::IteratorType::parallel);
+  }
+
+  SmallVector<Range> getIterationDomain(Operation *op, OpBuilder &b) const {
+    auto insertOp = cast<InsertSliceOp>(op);
+    OpFoldResult zero = b.getIndexAttr(0);
+    OpFoldResult one = b.getIndexAttr(1);
+    SmallVector<OpFoldResult> sourceSizes = tensor::getMixedSizes(
+        b, insertOp.getLoc(), insertOp.getSource());
+    SmallVector<Range> ranges(sourceSizes.size(), {zero, one, one});
+    for (auto [idx, size] : llvm::enumerate(sourceSizes))
+      ranges[idx].size = size;
+    return ranges;
+  }
+
+  FailureOr<TilingResult>
+  getTiledImplementation(Operation *op, OpBuilder &b,
+                         ArrayRef<OpFoldResult> offsets,
+                         ArrayRef<OpFoldResult> sizes) const {
+    auto insertOp = cast<InsertSliceOp>(op);
+    if (insertOp.getSourceType().getRank() != insertOp.getDestType().getRank())
+      return failure();
+    // The source tile is contiguous; the stride lives only in the writeback.
+    SmallVector<OpFoldResult> unitStrides(offsets.size(), b.getIndexAttr(1));
+    auto extractOp = ExtractSliceOp::create(b, insertOp.getLoc(),
+                                            insertOp.getSource(), offsets, sizes,
+                                            unitStrides);
+    return TilingResult{{extractOp}, {extractOp.getResult()}, {}};
+  }
+
+  LogicalResult
+  getResultTilePosition(Operation *op, OpBuilder &b, unsigned resultNumber,
+                        ArrayRef<OpFoldResult> offsets,
+                        ArrayRef<OpFoldResult> sizes,
+                        SmallVector<OpFoldResult> &resultOffsets,
+                        SmallVector<OpFoldResult> &resultSizes) const {
+    auto insertOp = cast<InsertSliceOp>(op);
+    if (insertOp.getSourceType().getRank() != insertOp.getDestType().getRank())
+      return failure();
+    Location loc = insertOp.getLoc();
+    SmallVector<OpFoldResult> mixedOffsets = insertOp.getMixedOffsets();
+    SmallVector<OpFoldResult> mixedStrides = insertOp.getMixedStrides();
+    // resultOffset[d] = insertBase[d] + iterOffset[d] * stride[d]. The dest
+    // span offset+(size-1)*stride is implicit (verifyInsertSliceOp is
+    // sizes-only), so resultSizes = iterSizes = the source/`%tile` shape.
+    AffineExpr d0, d1, s0;
+    bindDims(b.getContext(), d0, d1);
+    bindSymbols(b.getContext(), s0);
+    AffineMap strideMap = AffineMap::get(2, 1, d0 + d1 * s0);
+    resultOffsets.reserve(offsets.size());
+    for (auto [iterOffset, base, stride] :
+         llvm::zip_equal(offsets, mixedOffsets, mixedStrides)) {
+      resultOffsets.push_back(affine::makeComposedFoldedAffineApply(
+          b, loc, strideMap, {base, iterOffset, stride}));
+    }
+    resultSizes.assign(sizes.begin(), sizes.end());
+    return success();
+  }
+
+  LogicalResult
+  getResultTileStrides(Operation *op, OpBuilder &b, unsigned resultNumber,
+                       ArrayRef<OpFoldResult> offsets,
+                       ArrayRef<OpFoldResult> sizes,
+                       SmallVector<OpFoldResult> &resultStrides) const {
+    resultStrides = cast<InsertSliceOp>(op).getMixedStrides();
+    return success();
+  }
+};
+
 } // namespace

